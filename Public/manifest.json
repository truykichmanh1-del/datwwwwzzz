{
  "manifest_version": 3,
  "name": "MikuSolver",
  "version": "1.0.4",
  "version_name": "v1.0.4",
  "description": "Tự động giải FunCAPTCHA bằng MikuSolver.",
  "minimum_chrome_version": "102.0",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "content/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "MikuSolver",
    "default_icon": "icon/16.png",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "128": "icon/128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.arkoselabs.com/fc/*",
        "*://*.funcaptcha.com/fc/*",
        "*://*/fc/assets/*"
      ],
      "js": [
        "content/funcaptcha.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
